<UserControl x:Class="GTweak.View.DataSystemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:b="clr-namespace:GTweak.Core.Behaviors"
             xmlns:vm="clr-namespace:GTweak.Core.ViewModel" 
             xmlns:uc="clr-namespace:GTweak.Assets.UserControls"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:anim="clr-namespace:GTweak.Utilities.Animation"
             xmlns:conv="clr-namespace:GTweak.Core.Converters"
             xmlns:local="clr-namespace:GTweak.View"
             mc:Ignorable="d" d:Width="1014" Style="{StaticResource LaunchPage}">
    <UserControl.DataContext>
        <vm:DataSystemViewModel/>
    </UserControl.DataContext>
    <UserControl.Resources>
        <conv:AngleToPercentConverter x:Key="AngleToPercent"/>
        <conv:UsageToAngleConverter x:Key="UsageToAngle"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Popup x:Name="PopupCopy" AllowsTransparency="True" Placement="Mouse" HorizontalOffset="20">
            <Border x:Name="CopyTextToastBody" Opacity="0" Background="{StaticResource Brush_Background_ComboBox}" BorderBrush="{StaticResource Brush_Separator}" BorderThickness="1" CornerRadius="5" Padding="5" Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center" Panel.ZIndex="1">
                <Border.LayoutTransform>
                    <ScaleTransform ScaleX="0.85" ScaleY="0.85"/>
                </Border.LayoutTransform>
                <Border.CacheMode>
                    <BitmapCache RenderAtScale="2" />
                </Border.CacheMode>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="5" Opacity="0.3" ShadowDepth="2"/>
                </Border.Effect>
                <Label Content="{DynamicResource text_copy_sysinfo}" Foreground="{StaticResource Brush_Highlighted}" FontFamily="{StaticResource Jura}" FontSize="12" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                    <Label.CacheMode>
                        <BitmapCache RenderAtScale="2" EnableClearType="True"/>
                    </Label.CacheMode>
                    <Label.Effect>
                        <DropShadowEffect Opacity="0.2"/>
                    </Label.Effect>
                </Label>
            </Border>
        </Popup>

        <Grid Grid.Row="0" Margin="10">
            <Border CornerRadius="8" Opacity="0.5" Background="{StaticResource Brush_ShadowOverlay}" IsHitTestVisible="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Border.RenderTransform>
                    <TranslateTransform X="3" Y="6" />
                </Border.RenderTransform>
            </Border>

            <Border x:Name="CardBody" BorderBrush="{StaticResource Brush_Separator}" BorderThickness="1" Background="{StaticResource Brush_Background_Card}" CornerRadius="8" Padding="15,12" HorizontalAlignment="Stretch" VerticalAlignment="Top" SnapsToDevicePixels="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" VerticalAlignment="Center" Margin="0,0,15,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" VerticalAlignment="Stretch" Margin="0,0,12,0" Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}">
                            <Border.CacheMode>
                                <BitmapCache RenderAtScale="2"/>
                            </Border.CacheMode>
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding DisplayWallpaper, TargetNullValue={StaticResource Icon_LogoWin}, Mode=OneWay}" Stretch="UniformToFill"/>
                            </Border.Background>
                            <Border.OpacityMask>
                                <ImageBrush ImageSource="{StaticResource Icon_LogoWin}" Stretch="Uniform"/>
                            </Border.OpacityMask>
                            <Border.Effect>
                                <DropShadowEffect Opacity="{StaticResource DataElement_Opacity}" BlurRadius="8" ShadowDepth="4"/>
                            </Border.Effect>
                        </Border>

                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource TextDefault}" FontSize="14pt" TextWrapping="Wrap">
                                <Run Foreground="{StaticResource Brush_Highlighted}" Text="{Binding [OSName].Data}" PreviewMouseDown="HandleCopyingData_PreviewMouseDown" Cursor="Hand"/><LineBreak/>
                                <Run Foreground="{StaticResource Brush_Inactive}" Text="{Binding [OSVersion].Data}" PreviewMouseDown="HandleCopyingData_PreviewMouseDown" Cursor="Hand"/>
                            </TextBlock>

                            <TextBlock Grid.Row="1" FontFamily="{StaticResource Jura}" FontSize="13" Foreground="{StaticResource Brush_TextBlock_Inactivity}" Margin="0,3,0,0" TextWrapping="Wrap">
                            <Run Text="{DynamicResource label_proc_sysinfo}"/>
                                <InlineUIContainer>
                                    <TextBlock anim:NumberAnimation.Value="{Binding [Processes].Data}" Text="0" Margin="0,0.5,0,0" FontFamily="{StaticResource Play}" Typography.NumeralAlignment="Tabular" Typography.NumeralStyle="Lining" FontSize="12.5"/>
                                </InlineUIContainer>
                            <Run Text=" • "/>
                        <Run Text="{DynamicResource label_svc_sysinfo}"/>
                        <InlineUIContainer>
                            <TextBlock anim:NumberAnimation.Value="{Binding [Services].Data}" Text="0" Margin="0,0.5,0,0" FontFamily="{StaticResource Play}" Typography.NumeralAlignment="Tabular" Typography.NumeralStyle="Lining" FontSize="12.5"/>
                        </InlineUIContainer>
                    </TextBlock>
                        </Grid>
                    </Grid>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">

                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,0,10,0">
                            <Grid Width="60" Height="60">
                                <Ellipse Stroke="{StaticResource Brush_Separator}" StrokeThickness="3" Width="60" Height="60" Opacity="{StaticResource DataElement_Opacity}"/>
                                <ui:Arc b:ArcAnimationBehavior.AnimatedAngle="{Binding [CPUAngle].Data, Converter={StaticResource UsageToAngle}}" x:Name="CPULoad" Width="60" Height="60" Stroke="{StaticResource Brush_Accent_B}" StrokeThickness="3" VerticalAlignment="Center" HorizontalAlignment="Center" EndAngle="0"/>
                                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Style="{StaticResource TextDefault}" FontSize="12" Foreground="{StaticResource Brush_Inactive}">
                                    <InlineUIContainer>
                                        <TextBlock Style="{StaticResource TextDefault}" FontSize="12" Foreground="{StaticResource Brush_Inactive}" anim:NumberAnimation.Value="{Binding ElementName=CPULoad, Path=EndAngle, Converter={StaticResource AngleToPercent}, FallbackValue=0}"/>
                                    </InlineUIContainer><Run Text="%"/>
                                </TextBlock>
                            </Grid>
                            
                            <Border Background="{StaticResource Brush_Background_Labels_B}" CornerRadius="5" Padding="8,2" Margin="0,4,0,0" HorizontalAlignment="Center">
                                <TextBlock Text="CPU" Foreground="{StaticResource Brush_Accent_B}" Style="{StaticResource TextDefault}" FontSize="13"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <Grid Width="60" Height="60">
                                <Ellipse Stroke="{StaticResource Brush_Separator}" StrokeThickness="3" Width="60" Height="60" Opacity="{StaticResource DataElement_Opacity}"/>
                                <ui:Arc b:ArcAnimationBehavior.AnimatedAngle="{Binding [RAMAngle].Data, Converter={StaticResource UsageToAngle}}" x:Name="RAMLoad" Width="60" Height="60" Stroke="{StaticResource Brush_Accent}" StrokeThickness="3" VerticalAlignment="Center" HorizontalAlignment="Center" EndAngle="0"/>
                                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Style="{StaticResource TextDefault}" FontSize="12" Foreground="{StaticResource Brush_Inactive}">
                                    <InlineUIContainer>
                                        <TextBlock Style="{StaticResource TextDefault}" FontSize="12" Foreground="{StaticResource Brush_Inactive}" anim:NumberAnimation.Value="{Binding ElementName=RAMLoad, Path=EndAngle, Converter={StaticResource AngleToPercent}, FallbackValue=0}"/>
                                    </InlineUIContainer><Run Text="%"/>
                                </TextBlock>
                            </Grid>
                            
                            <Border Background="{StaticResource Brush_Background_Labels}" CornerRadius="5" Padding="8,2" Margin="0,4,0,0" HorizontalAlignment="Center">
                                <TextBlock Text="RAM" Foreground="{StaticResource Brush_Accent}" Style="{StaticResource TextDefault}" FontSize="13"/>
                            </Border>
                        </StackPanel>

                    </StackPanel>
                    
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <ScrollViewer b:ScrollFadeBehavior.EnableFade="True" Margin="0,0,0,10" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <WrapPanel Grid.Column="0" Orientation="Vertical">

                        <Grid Margin="10">
                            <Border CornerRadius="8" Opacity="0.5" Background="{StaticResource Brush_ShadowOverlay}" IsHitTestVisible="False">
                                <Border.RenderTransform>
                                    <TranslateTransform X="3" Y="6"/>
                                </Border.RenderTransform>
                            </Border>

                            <Border BorderBrush="{StaticResource Brush_Separator}" BorderThickness="1" Background="{StaticResource Brush_Background_Card}" CornerRadius="8" Padding="15,12" SnapsToDevicePixels="True">
                                <StackPanel Orientation="Vertical">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                        <Image Height="16" Width="16" VerticalAlignment="Bottom">
                                            <Image.Style>
                                                <Style TargetType="{x:Type Image}">
                                                    <Setter Property="Source" Value="{StaticResource Icon_Bios}"/>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                        <TextBlock Margin="5,0,0,0" Text="{DynamicResource label_bios_sysinfo}" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Accent}"/>
                                    </StackPanel>

                                    <Border Background="{StaticResource Brush_Separator}" Height="1" CornerRadius="10" Margin="0,10,0,10"/>

                                    <Grid Margin="0,2,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{DynamicResource label_verison_sysinfo}" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Inactive}"/>
                                        <TextBlock Grid.Column="2" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Highlighted}" Text="{Binding [Bios].Data}" PreviewMouseDown="HandleCopyingData_PreviewMouseDown" Cursor="Hand"/>
                                    </Grid>

                                    <Grid Margin="0,2,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{DynamicResource label_serial_sysinfo}" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Inactive}"/>
                                        <TextBlock Grid.Column="2" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Highlighted}" Text="{Binding [BiosSerial].Data}" PreviewMouseDown="HandleCopyingData_PreviewMouseDown" Cursor="Hand"/>
                                    </Grid>

                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{DynamicResource label_mode_sysinfo}" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Inactive}"/>
                                        <Border Grid.Column="2" Padding="8,2" CornerRadius="5">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource Brush_Background_Labels}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding [Mode].Data}" Value="Legacy Boot">
                                                            <Setter Property="Background" Value="{StaticResource Brush_Background_Labels_P}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource TextDefault}">
                                                        <Setter Property="Foreground" Value="{StaticResource Brush_Accent}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding [Mode].Data}" Value="Legacy Boot">
                                                                <Setter Property="Foreground" Value="{StaticResource Brush_Accent_P}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                                <Run Text="{Binding [Mode].Data}"/>
                                            </TextBlock>
                                        </Border>
                                    </Grid>

                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Margin="10">
                            <Border CornerRadius="8" Opacity="0.5" Background="{StaticResource Brush_ShadowOverlay}" IsHitTestVisible="False">
                                <Border.RenderTransform>
                                    <TranslateTransform X="3" Y="6"/>
                                </Border.RenderTransform>
                            </Border>

                            <Border BorderBrush="{StaticResource Brush_Separator}" BorderThickness="1" Background="{StaticResource Brush_Background_Card}" CornerRadius="8" Padding="15,12" SnapsToDevicePixels="True">
                                <StackPanel Orientation="Vertical">

                                    <StackPanel Orientation="Horizontal">
                                        <Image Height="16" Width="16" VerticalAlignment="Bottom">
                                            <Image.Style>
                                                <Style TargetType="{x:Type Image}">
                                                    <Setter Property="Source" Value="{StaticResource Icon_Motherboard}"/>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                        <TextBlock Margin="5,0,0,0" Text="{DynamicResource label_motherbr_sysinfo}" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Accent}"/>
                                    </StackPanel>

                                    <Border Background="{StaticResource Brush_Separator}" Height="1" CornerRadius="10" Margin="0,10,0,10"/>

                                    <Grid Margin="0,2,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{DynamicResource label_name_sysinfo}" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Inactive}"/>
                                        <TextBlock Grid.Column="2" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Highlighted}" Text="{Binding [Motherboard].Data}" IsEnabled="{Binding [Motherboard].IsEnabled}" PreviewMouseDown="HandleCopyingData_PreviewMouseDown" Cursor="Hand"/>
                                    </Grid>

                                    <Grid Margin="0,2,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{DynamicResource label_verison_sysinfo}" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Inactive}"/>
                                        <TextBlock Grid.Column="2" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Highlighted}" Text="{Binding [MotherboardVersion].Data}" IsEnabled="{Binding [MotherboardVersion].IsEnabled}"  PreviewMouseDown="HandleCopyingData_PreviewMouseDown" Cursor="Hand"/>
                                    </Grid>

                                    <Grid Margin="0,2,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{DynamicResource label_serial_sysinfo}" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Inactive}"/>
                                        <TextBlock Grid.Column="2" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Highlighted}" Text="{Binding [MotherboardSerial].Data}" IsEnabled="{Binding [MotherboardSerial].IsEnabled}" PreviewMouseDown="HandleCopyingData_PreviewMouseDown" Cursor="Hand"/>
                                    </Grid>

                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{DynamicResource label_chipset_sysinfo}" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Inactive}"/>
                                        <TextBlock Grid.Column="2" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Highlighted}" Text="{Binding [Chipset].Data}" IsEnabled="{Binding [Chipset].IsEnabled}" PreviewMouseDown="HandleCopyingData_PreviewMouseDown" Cursor="Hand"/>
                                    </Grid>

                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Margin="10">
                            <Border CornerRadius="8" Opacity="0.5" Background="{StaticResource Brush_ShadowOverlay}" IsHitTestVisible="False">
                                <Border.RenderTransform>
                                    <TranslateTransform X="3" Y="6"/>
                                </Border.RenderTransform>
                            </Border>

                            <Border BorderBrush="{StaticResource Brush_Separator}" BorderThickness="1" Background="{StaticResource Brush_Background_Card}" CornerRadius="8" Padding="15,12" SnapsToDevicePixels="True">
                                <StackPanel Orientation="Vertical">

                                    <StackPanel Orientation="Horizontal">
                                        <Image Height="16" Width="16" VerticalAlignment="Bottom">
                                            <Image.Style>
                                                <Style TargetType="{x:Type Image}">
                                                    <Setter Property="Source" Value="{StaticResource Icon_Processor}"/>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                        <TextBlock Margin="5,0,0,0" Text="{DynamicResource label_cpu_sysinfo}" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Accent}"/>
                                    </StackPanel>

                                    <Border Background="{StaticResource Brush_Separator}" Height="1" CornerRadius="10" Margin="0,10,0,10"/>

                                    <Grid Margin="0,2,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{DynamicResource label_name_sysinfo}" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Inactive}"/>
                                        <TextBlock Grid.Column="2" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Highlighted}" Text="{Binding [Processor].Data}" IsEnabled="{Binding [Processor].IsEnabled}" PreviewMouseDown="HandleCopyingData_PreviewMouseDown" Cursor="Hand"/>
                                    </Grid>

                                    <Grid Margin="0,2,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Inactive}">
                                            <Run Text="{DynamicResource label_cores_sysinfo}"/>
                                            <Run Text=" / "/>
                                            <Run Text="{DynamicResource label_threads_sysinfo}"/>
                                        </TextBlock>
                                        <TextBlock Grid.Column="2" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Highlighted}" IsEnabled="{Binding [MotherboardVersion].IsEnabled}"  PreviewMouseDown="HandleCopyingData_PreviewMouseDown" Cursor="Hand">
                                            <Run Text="{Binding [Cores].Data}"/>
                                            <Run Text=" / "/>
                                            <Run Text="{Binding [Threads].Data}"/>
                                        </TextBlock>
                                    </Grid>

                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{DynamicResource label_freq_sysinfo}" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Inactive}"/>
                                        <TextBlock Grid.Column="2" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Highlighted}" Text="{Binding [Frequency].Data}" IsEnabled="{Binding [Frequency].IsEnabled}" PreviewMouseDown="HandleCopyingData_PreviewMouseDown" Cursor="Hand"/>
                                    </Grid>

                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Margin="10">
                            <Border CornerRadius="8" Opacity="0.5" Background="{StaticResource Brush_ShadowOverlay}"
            IsHitTestVisible="False">
                                <Border.RenderTransform>
                                    <TranslateTransform X="3" Y="6"/>
                                </Border.RenderTransform>
                            </Border>

                            <Border BorderBrush="{StaticResource Brush_Separator}" BorderThickness="1" Background="{StaticResource Brush_Background_Card}" CornerRadius="8" Padding="15,12" SnapsToDevicePixels="True">
                                <StackPanel Orientation="Vertical">
                                    
                                    <StackPanel Orientation="Horizontal">
                                        <Image Height="16" Width="16" VerticalAlignment="Bottom">
                                            <Image.Style>
                                                <Style TargetType="{x:Type Image}">
                                                    <Setter Property="Source" Value="{StaticResource Icon_VideoCard}"/>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                        <TextBlock Margin="5,0,0,0" Text="{DynamicResource label_gpu_sysinfo}" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Accent}"/>
                                    </StackPanel>

                                    <Border Background="{StaticResource Brush_Separator}" Height="1.2" CornerRadius="10" Margin="0,10,0,10"/>

                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{DynamicResource label_name_sysinfo}" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Inactive}"/>
                                        <TextBlock Grid.Column="2" Text="{DynamicResource label_capacity_sysinfo}" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Inactive}"/>
                                    </Grid>

                                    <ItemsControl ItemsSource="{Binding [Graphics].Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="20"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Highlighted}" Text="{Binding DataItems[0]}" PreviewMouseDown="HandleCopyingData_PreviewMouseDown" Cursor="Hand"/>
                                                    <TextBlock Grid.Column="2" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Highlighted}" Text="{Binding DataItems[1]}" PreviewMouseDown="HandleCopyingData_PreviewMouseDown" Cursor="Hand"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border Background="{StaticResource Brush_Separator}" Height="1.2" CornerRadius="10" Margin="0,10,0,10"/>
                                    
                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{DynamicResource label_refreshrate_sysinfo}" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Inactive}"/>
                                        <Border Grid.Column="2" Padding="8,2" CornerRadius="5" Background="{StaticResource Brush_Background_Labels_Y}">
                                            <TextBlock Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Accent_Y}" Text="{Binding [RefreshRate].Data}" IsEnabled="{Binding [RefreshRate].IsEnabled}" PreviewMouseDown="HandleCopyingData_PreviewMouseDown" Cursor="Hand"/>
                                        </Border>
                                    </Grid>

                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Margin="10">
                            <Border CornerRadius="8" Opacity="0.5" Background="{StaticResource Brush_ShadowOverlay}" IsHitTestVisible="False">
                                <Border.RenderTransform>
                                    <TranslateTransform X="3" Y="6"/>
                                </Border.RenderTransform>
                            </Border>

                            <Border BorderBrush="{StaticResource Brush_Separator}" BorderThickness="1" Background="{StaticResource Brush_Background_Card}" CornerRadius="8" Padding="15,12" SnapsToDevicePixels="True">
                                <StackPanel Orientation="Vertical">

                                    <StackPanel Orientation="Horizontal">
                                        <Image Height="16" Width="16" VerticalAlignment="Bottom">
                                            <Image.Style>
                                                <Style TargetType="{x:Type Image}">
                                                    <Setter Property="Source" Value="{StaticResource Icon_Memory}"/>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                        <TextBlock Margin="5,0,0,0" Text="{DynamicResource label_ram_sysinfo}" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Accent}"/>
                                    </StackPanel>

                                    <Border Background="{StaticResource Brush_Separator}" Height="1.2" CornerRadius="10" Margin="0,10,0,6"/>

                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{DynamicResource label_name_sysinfo}" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Inactive}"/>
                                        <TextBlock Grid.Column="2" Text="{DynamicResource label_freq_sysinfo}" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Inactive}"/>
                                        <TextBlock Grid.Column="4" Text="{DynamicResource label_capacity_sysinfo}" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Inactive}"/>
                                    </Grid>

                                    <ItemsControl ItemsSource="{Binding [Memory].Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="20"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="20"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Highlighted}" Text="{Binding DataItems[0]}" PreviewMouseDown="HandleCopyingData_PreviewMouseDown" Cursor="Hand"/>
                                                    <TextBlock Grid.Column="2" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Highlighted}" Text="{Binding DataItems[1]}" PreviewMouseDown="HandleCopyingData_PreviewMouseDown" Cursor="Hand"/>
                                                    <TextBlock Grid.Column="4" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Highlighted}" Text="{Binding DataItems[2]}" PreviewMouseDown="HandleCopyingData_PreviewMouseDown" Cursor="Hand"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border Background="{StaticResource Brush_Separator}" Height="1.2" CornerRadius="10" Margin="0,10,0,10"/>

                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{DynamicResource label_mtype_sysinfo}" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Inactive}"/>
                                        <Border Grid.Column="2" Padding="8,2" CornerRadius="5" Background="{StaticResource Brush_Background_Labels}">
                                            <TextBlock Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Accent}" Text="{Binding [Type].Data}"/>
                                        </Border>
                                    </Grid>

                                </StackPanel>
                            </Border>
                        </Grid>

                    </WrapPanel>

                    <WrapPanel Grid.Column="1" Orientation="Vertical">

                        <StackPanel Orientation="Vertical">
                            <Border Padding="5,3,10,3" Background="{StaticResource Brush_Background_Labels}" CornerRadius="7" HorizontalAlignment="Left">
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Height="16" Width="16" VerticalAlignment="Bottom">
                                            <Image.Style>
                                                <Style TargetType="{x:Type Image}">
                                                    <Setter Property="Source" Value="{StaticResource Icon_Storage}"/>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                        <TextBlock Margin="5,0,0,0" Text="{DynamicResource label_storage_sysinfo}" Style="{StaticResource TextDefault}" HorizontalAlignment="Left" Foreground="{StaticResource Brush_Accent}" Height="Auto" Width="Auto"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <TextBlock Style="{StaticResource TextDefault}" HorizontalAlignment="Left" Margin="5,1,0,0" Foreground="{StaticResource Brush_Highlighted}" Height="Auto" Width="Auto">
                                 <Run Text="{Binding [Storage].Data}" IsEnabled="{Binding [Storage].IsEnabled}" PreviewMouseDown="HandleCopyingData_PreviewMouseDown" Cursor="Hand"/><LineBreak/>
                                 <Run Text="{DynamicResource label_storage_free_sysinfo}" Foreground="{StaticResource Brush_Toggle_Text}"/>
                                 <Run Text="{Binding [FreeSpace].Data}"/>
                                 <Run Text=" | " FontWeight="Bold" Foreground="{StaticResource Brush_Inactive}"/>
                                 <Run Text="{DynamicResource label_storage_used_sysinfo}"  Foreground="{StaticResource Brush_Toggle_Text}"/>
                                 <Run Text="{Binding [UsedSpace].Data}"/>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Orientation="Vertical" Margin="0,20,0,0">
                            <Border Padding="5,3,10,3" Background="{StaticResource Brush_Background_Labels}" CornerRadius="7" HorizontalAlignment="Left">
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Height="16" Width="16" VerticalAlignment="Bottom">
                                            <Image.Style>
                                                <Style TargetType="{x:Type Image}">
                                                    <Setter Property="Source" Value="{StaticResource Icon_SoundDevices}"/>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                        <TextBlock Margin="5,0,0,0" Text="{DynamicResource label_sound_sysinfo}" Style="{StaticResource TextDefault}" HorizontalAlignment="Left" Foreground="{StaticResource Brush_Accent}" Height="Auto" Width="Auto"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <TextBlock Text="{Binding [Audio].Data}" IsEnabled="{Binding [Audio].IsEnabled}" Style="{StaticResource TextDefault}" HorizontalAlignment="Left" Margin="5,1,0,0" Foreground="{StaticResource Brush_Highlighted}" Height="Auto" Width="Auto" PreviewMouseLeftButtonDown="HandleCopyingData_PreviewMouseDown" Cursor="Hand"/>
                        </StackPanel>

                        <StackPanel Orientation="Vertical" Margin="0,20,0,0">
                            <Border Padding="5,3,10,3" Background="{StaticResource Brush_Background_Labels}" CornerRadius="7" HorizontalAlignment="Left">
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Height="16" Width="16" VerticalAlignment="Bottom">
                                            <Image.Style>
                                                <Style TargetType="{x:Type Image}">
                                                    <Setter Property="Source" Value="{StaticResource Icon_Network}"/>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                        <TextBlock Margin="5,0,0,0" Text="{DynamicResource label_netadapter_sysinfo}" Style="{StaticResource TextDefault}" HorizontalAlignment="Left" Foreground="{StaticResource Brush_Accent}" Height="Auto" Width="Auto"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <TextBlock Text="{Binding [Network].Data}" IsEnabled="{Binding [Network].IsEnabled}" Style="{StaticResource TextDefault}" HorizontalAlignment="Left" Margin="5,1,0,0" Foreground="{StaticResource Brush_Highlighted}" Height="Auto" Width="Auto" PreviewMouseLeftButtonDown="HandleCopyingData_PreviewMouseDown" Cursor="Hand"/>
                        </StackPanel>

                        <StackPanel Orientation="Vertical" Margin="0,20,0,0">
                            <Border Padding="5,3,10,3" Background="{StaticResource Brush_Background_Labels}" CornerRadius="7" HorizontalAlignment="Left">
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Height="16" Width="16" VerticalAlignment="Bottom">
                                            <Image.Style>
                                                <Style TargetType="{x:Type Image}">
                                                    <Setter Property="Source" Value="{StaticResource Icon_IPaddress}"/>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                        <TextBlock Margin="5,0,0,0" Text="{DynamicResource label_ip_sysinfo}" Style="{StaticResource TextDefault}" HorizontalAlignment="Left" Foreground="{StaticResource Brush_Accent}" Height="Auto" Width="Auto"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <StackPanel Orientation="Horizontal" Margin="5,1,0,0">
                                <TextBlock x:Name="IpAddress" Text="{Binding [IpAddress].Data}" IsEnabled="{Binding [IpAddress].IsEnabled}" Style="{StaticResource TextDefault}" HorizontalAlignment="Left" Foreground="{StaticResource Brush_Highlighted}" Height="Auto" Width="Auto" PreviewMouseLeftButtonDown="HandleCopyingData_PreviewMouseDown" Cursor="Hand" anim:BlurAnimation.TargetRadius="{Binding SetBlurValue}">
                                    <TextBlock.Effect>
                                        <BlurEffect Radius="{Binding SetBlurValue}"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <ToggleButton x:Name="BtnVision" Margin="10,0,0,0" Width="24" Height="24" Visibility="{Binding SetVisibility}" VerticalAlignment="Center" Style="{StaticResource TglVision}" IsChecked="{Binding StateButtonVision, Mode=TwoWay}"/>
                            </StackPanel>
                        </StackPanel>

                    </WrapPanel>

                </Grid>

            </ScrollViewer>
        </Grid>

    </Grid>
</UserControl>
