    <v:String x:Key="tgl18_svc">Storitve, povezane z oddaljenim namizjem</v:String>
    <v:String x:Key="tgl19_svc">Storitve, ki zbirajo napake in dnevnike dogodkov</v:String>
    <v:String x:Key="tgl20_svc">Storitev za oddaljeno upravljanje datotek WebDAV</v:String>
    <v:String x:Key="tgl21_svc">Storitve, povezane z delovanjem pametne kartice</v:String>
    <v:String x:Key="tgl22_svc">Storitve, povezane z delovanjem Windows Kiosk</v:String>
    <v:String x:Key="tgl23_svc">Storitve, povezane s šifriranjem datotek</v:String>
    <v:String x:Key="tgl24_svc">Storitev, povezana z lokalizacijo Windows</v:String>
