    <v:String x:Key="tgl1_svc">Usługi związane z wyszukiwaniem Windows</v:String>
    <v:String x:Key="tgl2_svc">Usługi związane z Xbox</v:String>
    <v:String x:Key="tgl3_svc">Usługi związane z aktualizacjami Windows</v:String>
    <v:String x:Key="tgl4_svc">Usługi związane ze Sklepem Windows</v:String>
