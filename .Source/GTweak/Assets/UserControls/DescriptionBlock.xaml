<UserControl x:Class="GTweak.Assets.UserControls.DescriptionBlock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:b="clr-namespace:GTweak.Utilities.Behaviors"
             xmlns:local="clr-namespace:GTweak.Assets.UserControls"
             mc:Ignorable="d" IsTabStop="False" Focusable="False" KeyboardNavigation.TabNavigation="None" SnapsToDevicePixels="True" UseLayoutRounding="True"
             d:DesignHeight="100" d:DesignWidth="800">
    <Grid Margin="10,0,10,5">
        <Border CornerRadius="12" Background="Transparent" BorderThickness="1" BorderBrush="{StaticResource Brush_Background_ComboBox}">
            <Grid Margin="15,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Top" Opacity="0.8">
                    <TextBlock Text=">" FontFamily="{StaticResource Jura}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource Brush_Accent}"/>
                    <TextBlock x:Name="Caret" Text="_" FontFamily="{StaticResource Jura}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource Brush_Accent}"/>
                </StackPanel>

                <ScrollViewer x:Name="Scroller" Grid.Column="1" b:ScrollFadeBehavior.EnableFade="True" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled" ClipToBounds="True">
                    <TextBlock x:Name="FunctionDescription" Style="{StaticResource Description}" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" VerticalAlignment="Top" TextAlignment="Center" LineHeight="18" MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                </ScrollViewer>

                <StackPanel x:Name="StatusPanel" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="15,0,0,0" Opacity="0">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                        <Ellipse.CacheMode>
                            <BitmapCache RenderAtScale="2" />
                        </Ellipse.CacheMode>
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource Brush_Danger_Hover}"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="{StaticResource Color_Shadow_Danger}" BlurRadius="6" ShadowDepth="0" Opacity="0.8"/>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TargetState, RelativeSource={RelativeSource AncestorType=local:DescriptionBlock}}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource Brush_Accent}"/>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="{StaticResource Color_Shadow}" BlurRadius="6" ShadowDepth="0" Opacity="0.8"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>

                    <Grid VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource status_disabled}" FontSize="12" FontFamily="{StaticResource Jura}" Visibility="Hidden"/>
                        <TextBlock Text="{DynamicResource status_active}" FontSize="12" FontFamily="{StaticResource Jura}" Visibility="Hidden"/>
                        <TextBlock FontSize="12" FontFamily="{StaticResource Jura}" HorizontalAlignment="Left">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{DynamicResource status_disabled}"/>
                                    <Setter Property="Foreground" Value="{StaticResource Brush_Danger_Hover}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TargetState, RelativeSource={RelativeSource AncestorType=local:DescriptionBlock}}" Value="True">
                                            <Setter Property="Text" Value="{DynamicResource status_active}"/>
                                            <Setter Property="Foreground" Value="{StaticResource Brush_Accent}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
    
</UserControl>