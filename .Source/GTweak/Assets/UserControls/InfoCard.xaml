<UserControl x:Class="GTweak.Assets.UserControls.InfoCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GTweak.Assets.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="5">
        <Border CornerRadius="8" Opacity="0.5" Background="{StaticResource Brush_ShadowOverlay}"
                IsHitTestVisible="False">
            <Border.RenderTransform>
                <TranslateTransform X="3" Y="6"/>
            </Border.RenderTransform>
        </Border>

        <Border BorderBrush="{StaticResource Brush_Separator}" BorderThickness="1" Background="{StaticResource Brush_Background_Card}" CornerRadius="8" Padding="15,12" SnapsToDevicePixels="True">
            <StackPanel Orientation="Vertical">

                <StackPanel Orientation="Horizontal">
                    <Image x:Name="CardIcon" Height="16" Width="16" VerticalAlignment="Center"/>
                    <TextBlock Margin="5,0,0,0" Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}" Style="{StaticResource TextDefault}" Foreground="{StaticResource Brush_Accent}"/>
                </StackPanel>
                
                <Border Background="{StaticResource Brush_Separator}" Height="1" CornerRadius="10" Margin="0,10,0,0"/>

                <ContentPresenter Margin="0,8,0,0" Content="{Binding CardContent, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
