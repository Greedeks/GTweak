<ui:FluentWindow x:Class="GTweak.Windows.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:GTweak.Windows"
        mc:Ignorable="d" Icon="/GTweak.ico"
        Background="Transparent" WindowStyle="None" IsTabStop="False" SnapsToDevicePixels="True" UseLayoutRounding="True" KeyboardNavigation.TabNavigation="None"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica" ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Title="{DynamicResource title_win_update}" Topmost="True"
        SizeToContent="Width" Height="58" MinHeight="58" MaxHeight="58" MinWidth="200" Loaded="Window_Loaded">

    <Grid Background="{StaticResource Brush_Background_NavPanel}" MouseDown="TitleBar_MouseDown">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Column="0" Grid.RowSpan="2" Width="38" Height="38" CornerRadius="8" Background="{StaticResource Brush_Background_Labels}" BorderBrush="{StaticResource Brush_Accent}" BorderThickness="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="12,10,12,10">
            <ui:SymbolIcon Symbol="CloudArrowDown24" FontSize="20px" Foreground="{StaticResource Brush_Accent}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <TextBlock Grid.Column="1" Grid.Row="0" VerticalAlignment="Bottom" Margin="0,0,0,3" Style="{StaticResource TextDefault}" FontSize="15px">
            <Run Text="GTweak" Foreground="{StaticResource Brush_Highlighted}"/> <Run Text="{Binding DownloadVersion}" Foreground="{StaticResource Brush_Accent}"/>
        </TextBlock>

        <TextBlock Grid.Column="2" Grid.Row="0" VerticalAlignment="Bottom" Margin="50,0,12,3" FontSize="13px" Foreground="{StaticResource Brush_TextBlock_Inactivity}">
            <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource TextDefault}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ElementName=ProgressDownload, Path=Value}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
            <Run Text="{DynamicResource connecting}"/><InlineUIContainer BaselineAlignment="Baseline">
                <Border Width="16" Background="Transparent" VerticalAlignment="Bottom" Margin="0,0,0,-2">
                    <TextBlock x:Name="DotText" Style="{StaticResource TextDefault}" FontSize="14px" Foreground="{StaticResource Brush_TextBlock_Inactivity}">
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard Timeline.DesiredFrameRate="60" RepeatBehavior="Forever" Duration="0:0:1">
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="DotText" Storyboard.TargetProperty="Text">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0"   Value="" />
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="." />
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0.4" Value=".." />
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0.6" Value="..." />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                </Border>
            </InlineUIContainer>
        </TextBlock>

        <TextBlock Grid.Column="2" Grid.Row="0" VerticalAlignment="Bottom" Margin="30,0,12,3" FontFamily="{StaticResource Play}" FontSize="13px" Foreground="{StaticResource Brush_TextBlock_Inactivity}">
            <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource TextDefault}">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ElementName=ProgressDownload, Path=Value}" Value="0">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
            <Run Text="{Binding ElementName=ProgressDownload, Path=Value, Mode=OneWay, StringFormat=N0}"/>
            <Run Text="% · "/>
            <Run x:Name="SizeByte" Text="0/0"/>
        </TextBlock>

        <ProgressBar x:Name="ProgressDownload" Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="2" Value="0" Foreground="{StaticResource Brush_Accent}" Height="4" Margin="0,4,12,0" VerticalAlignment="Top"/>
    </Grid>

</ui:FluentWindow>